**/db_data/
**/config/

# ── Environment files (belt-and-suspenders; each service dir has its own) ────
**/.env

# ── Environment sync (gist clone and config) ──────────────────────────────────
.envs-gist/
.envs-gist.conf

# ── OS / editor artifacts ─────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo
